{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkTrace",
  "version": "0.1.5",
  "identifier": "app.worktrace.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WorkTrace",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "decorations": false,
        "transparent": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/josephmowjew/worktrace/main/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwREFDNzU2ODcwOEMyRTcKUldUbndnaUhWc2ZhVUxqOTJnSkxISTJXa0R6Mm1hQUlDa0hJeWhZTGl1dTFKM041UTZNYktoczQK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Joseph Mojoo",
    "copyright": "Copyright (c) 2026 Joseph Mojoo. All rights reserved.",
    "homepage": "https://github.com/josephmowjew/worktrace",
    "shortDescription": "WorkTrace, developed by Joseph Mojoo.",
    "longDescription": "WorkTrace is a local-first developer productivity and weekly reporting desktop app developed by Joseph Mojoo.",
    "resources": [
      "../CHANGELOG.md",
      "resources/voice/*",
      "resources/ai/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
